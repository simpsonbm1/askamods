#!/bin/sh
# askamods pre-commit: mechanizes CLAUDE.md's Ritual 1 (CLAUDE.md <-> AGENTS.md drift) and
# Ritual 3 (duplication guard). Blocks the commit with a specific report on any mismatch.
# Enable once per clone:  git config core.hooksPath .githooks
# (Do NOT bypass with --no-verify; fix the drift instead — that's the whole point.)

set -u
cd "$(git rev-parse --show-toplevel)" || exit 1

C="CLAUDE.md"
A=".agents/AGENTS.md"
fail=0
err() { echo "RITUAL FAIL: $1" >&2; fail=1; }

[ -f "$C" ] || { echo "RITUAL FAIL: $C missing" >&2; exit 1; }
[ -f "$A" ] || { echo "RITUAL FAIL: $A missing" >&2; exit 1; }

# --- Ritual 3: integrity guard (exactly one body per orientation file) ---
for f in "$C" "$A"; do
    n=$(grep -c "^# AskaMods" "$f")
    [ "$n" -eq 1 ] || err "$f contains $n '# AskaMods' headers (must be exactly 1 — duplicated body?)"
done

# --- Ritual 1a: every mod folder appears in BOTH files ---
# A "mod" is a top-level directory containing <Dir>/<Dir>.csproj.
for csproj in */*.csproj; do
    [ -f "$csproj" ] || continue
    mod=$(dirname "$csproj")
    [ "$mod" = "_explore" ] && continue
    grep -q "$mod/" "$C" || err "$mod missing from $C Project Structure"
    grep -q "$mod/" "$A" || err "$mod missing from $A Project Structure"

    # --- Ritual 1b: stated version matches the code ---
    # Ground truth = csproj <Version>. If the mod's tree line states a version (first vN.N.N
    # on the line matching '<mod>/'), it must equal the csproj.
    ver=$(sed -n 's/.*<Version>\([0-9][0-9.]*\)<\/Version>.*/\1/p' "$csproj" | head -1)
    if [ -n "$ver" ]; then
        for f in "$C" "$A"; do
            line=$(grep "  $mod/" "$f" | head -1)
            [ -z "$line" ] && line=$(grep "$mod/" "$f" | head -1)
            stated=$(printf '%s' "$line" | grep -o 'v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*' | head -1 | tr -d 'v')
            if [ -n "$stated" ] && [ "$stated" != "$ver" ]; then
                err "$mod: $f states v$stated but $csproj says $ver"
            fi
        done

        # --- Ritual 1c: PLUGIN_VERSION (if the mod defines one) matches csproj <Version> ---
        # Catches the half-bump that Smart App Control punishes with a stale-looking load.
        pv=$(grep -rh 'PLUGIN_VERSION = "' "$mod" --include="*.cs" 2>/dev/null \
             | sed -n 's/.*PLUGIN_VERSION = "\([0-9.]*\)".*/\1/p' | head -1)
        if [ -n "$pv" ] && [ "$pv" != "$ver" ]; then
            err "$mod: PLUGIN_VERSION=$pv but csproj <Version>=$ver (bump BOTH — SAC gotcha)"
        fi
    fi
done

# --- Ritual 1d: every handoff/mod doc is referenced in BOTH Documentation Maps ---
for doc in *HANDOFF*.md docs/mods/*.md; do
    [ -f "$doc" ] || continue
    base=$(basename "$doc")
    [ "$base" = "SESSION_HANDOFF.md" ] && continue   # gitignored continuity buffer, not a doc
    grep -q "$base" "$C" || err "$base not referenced in $C Documentation Map"
    grep -q "$base" "$A" || err "$base not referenced in $A Documentation Map"
done

# --- Parked-mod consistency: PARKED in the tree line => in sync-plugins.ps1 ParkedByDefault ---
if [ -f "sync-plugins.ps1" ]; then
    parked_list=$(sed -n '/\$ParkedByDefault/,/)/p' sync-plugins.ps1)
    grep "PARKED" "$C" | grep -o '^  [A-Za-z]*Mod/' | tr -d ' /' | while read -r pm; do
        echo "$parked_list" | grep -q "$pm" || \
            echo "RITUAL WARN: $pm marked PARKED in $C but not in sync-plugins.ps1 \$ParkedByDefault" >&2
    done
fi

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "Commit blocked by .githooks/pre-commit (Rituals 1+3, see CLAUDE.md)." >&2
    echo "Fix the drift in BOTH orientation files, then commit again." >&2
    exit 1
fi
exit 0
