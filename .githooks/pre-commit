#!/bin/sh
# askamods pre-commit: single-source orientation guard — CLAUDE.md is the canonical orientation.
# - AUTO-FIXES stale mod version tokens in CLAUDE.md from each csproj <Version> (and re-stages).
# - BLOCKS on structural drift: mod folder or doc missing from CLAUDE.md, PLUGIN_VERSION !=
#   csproj <Version> (the SAC half-bump — a text fix can't fix a DLL, it needs a rebuild),
#   duplicated CLAUDE.md body, or an AGENTS.md stub that lost its pointer marker / started
#   re-growing a full orientation body.
# Enable once per clone:  git config core.hooksPath .githooks
# (Do NOT bypass with --no-verify; fix the drift instead — that's the whole point.)

set -u

# Emit "<fileLineNo> <version>" for the FIRST vX.Y.Z token inside a mod's ENTIRE Project
# Structure entry — its "  <mod>/" tree line THROUGH the closing ']' of the bracketed blurb.
# A wrapped blurb can carry the version token on a continuation line, not the tree line
# (OuthouseComposter regression, 2026-07-21): scanning only the tree line silently skips BOTH
# the auto-fix and the drift block, committing a stale token. Prints nothing if none is found.
# Args: <file> <mod>.  Verify with:  sh .githooks/pre-commit --selftest
entry_version() {
    awk -v mod="$2" '
        index($0, "  " mod "/") == 1 { instr = 1 }
        instr {
            if (match($0, /v[0-9]+\.[0-9]+\.[0-9]+/)) { print NR, substr($0, RSTART + 1, RLENGTH - 1); exit }
            if (index($0, "]") > 0) exit   # reached the end of the entry with no token
        }
    ' "$1"
}

# --- Self-test: exercise entry_version + the auto-fix replace on all three entry shapes ---
# Regression lock for the wrapped-blurb blind spot. Run: sh .githooks/pre-commit --selftest
if [ "${1:-}" = "--selftest" ]; then
    tmp=$(mktemp) || { echo "SELFTEST: mktemp failed" >&2; exit 1; }
    # Mirrors the three real entry shapes: single-line, wrapped-token-on-line-1, and
    # wrapped-token-on-a-CONTINUATION-line (the OuthouseComposter shape).
    cat > "$tmp" <<'SELFTEST_EOF'
  FooMod/                    ← Mod 1: single-line entry [COMPLETE v1.0.0 — docs/mods/foo.md]
  BarMod/                    ← Mod 2: wrapped blurb, token on the FIRST line [COMPLETE v2.0.0 —
                                more prose continuing here — docs/mods/bar.md]
  BazMod/                    ← Mod 3: wrapped blurb whose text runs long,
                                more clauses (a parenthetical) [COMPLETE
                                v3.1.4, on Nexus — docs/mods/baz.md]
SELFTEST_EOF
    st_fail=0
    st_check() {  # <mod> <expected-version>
        got=$(entry_version "$tmp" "$1"); gv=${got#* }
        if [ "$gv" = "$2" ]; then echo "  ok   detect $1 -> v$gv"
        else echo "  FAIL detect $1 -> got '[$got]', expected v$2"; st_fail=1; fi
    }
    echo "entry_version detection:"
    st_check FooMod 1.0.0
    st_check BarMod 2.0.0
    st_check BazMod 3.1.4    # regression: token on the 3rd (continuation) line
    echo "auto-fix on a continuation-line token (BazMod v3.1.4 -> v3.2.0):"
    hit=$(entry_version "$tmp" BazMod); vline=${hit%% *}
    sed -b -i "${vline}s/v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*/v3.2.0/" "$tmp"
    av=$(entry_version "$tmp" BazMod); av=${av#* }
    if [ "$av" = "3.2.0" ]; then echo "  ok   rewrote continuation-line token to v$av"
    else echo "  FAIL post-fix got '$av' (expected 3.2.0)"; st_fail=1; fi
    fv=$(entry_version "$tmp" FooMod); fv=${fv#* }
    if [ "$fv" = "1.0.0" ]; then echo "  ok   single-line FooMod left untouched (v$fv)"
    else echo "  FAIL single-line FooMod changed to v$fv"; st_fail=1; fi
    rm -f "$tmp"
    if [ "$st_fail" -eq 0 ]; then echo "SELFTEST: PASS"; exit 0; else echo "SELFTEST: FAIL"; exit 1; fi
fi

cd "$(git rev-parse --show-toplevel)" || exit 1

C="CLAUDE.md"
fail=0
err() { echo "RITUAL FAIL: $1" >&2; fail=1; }

[ -f "$C" ] || { echo "RITUAL FAIL: $C missing" >&2; exit 1; }

# --- Integrity guard: exactly one body in the canonical file ---
n=$(grep -c "^# AskaMods" "$C")
[ "$n" -eq 1 ] || err "$C contains $n '# AskaMods' headers (must be exactly 1 — duplicated body?)"

# --- Stub guard: the AGENTS.md pointer files must stay stubs ---
for s in AGENTS.md .agents/AGENTS.md; do
    if [ ! -f "$s" ]; then err "$s missing"; continue; fi
    grep -q "ORIENTATION-STUB" "$s" || \
        err "$s lost its ORIENTATION-STUB marker (it must stay a pointer stub — see CLAUDE.md)"
    if grep -q "^## Project Structure" "$s"; then
        err "$s is re-growing a full orientation body ('## Project Structure' found) — project content belongs ONLY in $C"
    fi
done

# --- Every mod folder appears in CLAUDE.md; stale version tokens are AUTO-FIXED from csproj ---
fixed=0
for csproj in */*.csproj; do
    [ -f "$csproj" ] || continue
    mod=$(dirname "$csproj")
    [ "$mod" = "_explore" ] && continue
    if ! grep -q "$mod/" "$C"; then
        err "$mod missing from $C Project Structure"
        continue
    fi

    ver=$(sed -n 's/.*<Version>\([0-9][0-9.]*\)<\/Version>.*/\1/p' "$csproj" | head -1)
    if [ -n "$ver" ]; then
        # Scan the mod's ENTIRE Project Structure entry (tree line through closing ']'), not
        # just the tree line — the token may live on a wrapped continuation line.
        hit=$(entry_version "$C" "$mod")
        vline=${hit%% *}
        stated=${hit#* }
        if [ -n "$stated" ] && [ "$stated" != "$ver" ]; then
            # Auto-fix: replace the FIRST version token on the exact line it was found on.
            # -b (binary) is REQUIRED: without it, MSYS sed silently rewrites the whole
            # CRLF file to LF (caught in scratch testing 2026-07-16).
            sed -b -i "${vline}s/v[0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*/v$ver/" "$C"
            stated2=$(entry_version "$C" "$mod"); stated2=${stated2#* }
            if [ "$stated2" = "$ver" ]; then
                echo "AUTO-FIXED: $C $mod v$stated -> v$ver (from $csproj)" >&2
                fixed=1
            else
                err "$mod: $C states v$stated, csproj says $ver, and auto-fix failed — fix by hand"
            fi
        fi

        # PLUGIN_VERSION half-bump stays BLOCKING: the DLL hash is wrong, not the text.
        pv=$(grep -rh 'PLUGIN_VERSION = "' "$mod" --include="*.cs" 2>/dev/null \
             | sed -n 's/.*PLUGIN_VERSION = "\([0-9.]*\)".*/\1/p' | head -1)
        if [ -n "$pv" ] && [ "$pv" != "$ver" ]; then
            err "$mod: PLUGIN_VERSION=$pv but csproj <Version>=$ver (bump BOTH — SAC gotcha; needs a rebuild, not a text fix)"
        fi
    fi
done
[ "$fixed" -eq 1 ] && git add "$C"

# --- Every handoff/mod doc is referenced in CLAUDE.md's Documentation Map ---
for doc in *HANDOFF*.md docs/mods/*.md; do
    [ -f "$doc" ] || continue
    base=$(basename "$doc")
    [ "$base" = "SESSION_HANDOFF.md" ] && continue   # gitignored continuity buffer, not a doc
    grep -q "$base" "$C" || err "$base not referenced in $C Documentation Map"
done

# --- Parked-mod consistency: PARKED in the tree line => in sync-plugins.ps1 ParkedByDefault ---
if [ -f "sync-plugins.ps1" ]; then
    parked_list=$(sed -n '/\$ParkedByDefault/,/)/p' sync-plugins.ps1)
    grep "PARKED" "$C" | grep -o '^  [A-Za-z]*Mod/' | tr -d ' /' | while read -r pm; do
        echo "$parked_list" | grep -q "$pm" || \
            echo "RITUAL WARN: $pm marked PARKED in $C but not in sync-plugins.ps1 \$ParkedByDefault" >&2
    done
fi

# --- Doc hygiene: no "journey language" in ADDED documentation lines ---
# Backstop for the PreToolUse doc-hygiene guard (.claude/hooks/doc-hygiene-guard.ps1), which only
# sees Write/Edit/MultiEdit. This catches doc text that arrived by any other path (sed, a subagent,
# a hand edit, a merge). Scans only ADDED lines, so pre-existing prose never blocks an unrelated
# commit. Docs record current truth, not the journey — see CLAUDE.md "Doc update style".
guard=".claude/hooks/doc-hygiene-guard.ps1"
if [ -f "$guard" ] && command -v powershell.exe >/dev/null 2>&1; then
    added=$(git diff --cached -U0 -- '*.md' | grep '^+' | grep -v '^+++' | sed 's/^+//')
    if [ -n "$added" ]; then
        if ! printf '%s\n' "$added" \
             | powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$guard" -ScanStdin; then
            err "journey language in added doc lines (rewrite the fact in place — see above)"
        fi
    fi
fi

# --- Surface doc-hygiene BLOCKS for human review (informational; never blocks the commit) ---
# A guard block is only visible in the model's tool result, so without this the user can never
# audit whether a block was legitimate — and a false positive would silently bend the writing.
# Shows only blocks since the last commit, i.e. the ones from the work being committed.
if [ -f "$guard" ] && command -v powershell.exe >/dev/null 2>&1; then
    since=$(git log -1 --format=%ct 2>/dev/null || echo 0)
    CLAUDE_PROJECT_DIR="$(pwd)" powershell.exe -NoProfile -ExecutionPolicy Bypass \
        -File "$guard" -ShowBlocks -SinceEpoch "$since" || true
fi

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "Commit blocked by .githooks/pre-commit (see CLAUDE.md rituals)." >&2
    exit 1
fi
exit 0
